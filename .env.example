APP_NAME=RecoTicket
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_AR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ──────────────────────────────────────────────────────────────
# BASE DE DATOS — Supabase PostgreSQL (staging / producción)
# ──────────────────────────────────────────────────────────────
# Obtené la cadena de conexión en:
#   Supabase → Project Settings → Database → Connection string → URI
#   Usá el "Session Pooler" (puerto 5432) para shared hosting / Hostinger.
#
DB_CONNECTION=pgsql
DB_URL=
DB_SCHEMA=app,public
DB_SSLMODE=require

# ──────────────────────────────────────────────────────────────
# BASE DE DATOS — SQLite (desarrollo local, opcional)
# ──────────────────────────────────────────────────────────────
# Para desarrollo rápido sin Supabase podés usar SQLite:
#   1. Comentá las cuatro líneas de arriba (DB_CONNECTION, DB_URL, etc.)
#   2. Descomentá las tres líneas de abajo
#   3. Creá el archivo:  touch database/database.sqlite
#
# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite
# DB_SSLMODE=disable

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@recoticket.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ──────────────────────────────────────────────────────────────
# MERCADO PAGO
# ──────────────────────────────────────────────────────────────
# Sandbox: https://www.mercadopago.com.ar/developers/es/docs/checkout-api/integration-test/sandbox-mode
# Producción: https://www.mercadopago.com.ar/developers/panel
#
MP_PUBLIC_KEY=
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# ──────────────────────────────────────────────────────────────
# WHATSAPP NOTIFICATIONS
# ──────────────────────────────────────────────────────────────
# Provider options: stub (logs only), twilio, meta
# Replace stub with a real provider before going to production.
#
WHATSAPP_PROVIDER=stub
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_FROM_NUMBER=

